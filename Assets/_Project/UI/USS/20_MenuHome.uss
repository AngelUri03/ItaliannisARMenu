/* =========================================================
   20_MenuHome.uss
   Vista principal del men·
   Ajuste fijo para Samsung Galaxy Tab S10 FE horizontal
   Sin panel izquierdo / panel derecho amplio
   ========================================================= */

/* =========================================================
   Base
   ========================================================= */

.menu-home-view {
    width: 100%;
    height: 100%;
    overflow: hidden;
    background-color: #070504;
    flex-direction: column;
}

/* =========================================================
   Top bar
   ========================================================= */

.menu-top-bar {
    height: 120px;

    background-color: rgba(111, 23, 23, 0.96);

    border-bottom-width: 1px;
    border-bottom-color: rgba(214, 170, 91, 0.45);

    flex-direction: row;
    justify-content: space-between;
    align-items: center;

    padding-left: 42px;
    padding-right: 42px;
}

.menu-brand-block {
    flex-direction: column;
}

.menu-brand-title {
    -unity-font-definition: url("../Fonts/Generated/BrandFont.asset");
    font-size: 50px;
    -unity-font-style: bold;
    color: var(--color-text);
    letter-spacing: 2px;
}

.menu-brand-subtitle {
    -unity-font-definition: url("../Fonts/Generated/InterfaceFontSemiBold.asset");
    font-size: 12px;
    color: var(--color-gold-soft);
    letter-spacing: 4px;
    margin-top: -4px;
}

.menu-top-actions {
    flex-direction: row;
    align-items: center;
}

.menu-top-actions .pill {
    height: 55px;
    min-width: 120px;
    border-radius: 20px;

    font-size: 15px;
    margin-left: 10px;

    padding-left: 16px;
    padding-right: 16px;
    padding-top: 18px;
}

.menu-top-actions .pill-left {
    padding-left: 26px;
}

.menu-top-actions .pill-left-2 {
    padding-left: 22px;
}

/* =========================================================
   Main layout
   ========================================================= */

.menu-content {
    height: 1340px;

    flex-direction: row;

    padding-left: 32px;
    padding-right: 32px;
    padding-top: 26px;
    padding-bottom: 76px;
}

/* Panel izquierdo removido del UXML. Se deja oculto por seguridad. */
.menu-sidebar {
    display: none;
    width: 0;
    height: 0;
    margin: 0;
    padding: 0;
}

/* =========================================================
   Panel central estable
   ========================================================= */

.menu-main-panel {
    width: 1680px;
    height: 1150px;

    flex-shrink: 0;

    background-color: rgba(16, 11, 8, 0.92);

    border-radius: 30px;

    border-width: 1px;
    border-color: rgba(214, 170, 91, 0.28);

    padding: 24px;

    margin-right: 26px;
}

/* =========================================================
   Header central
   ========================================================= */

.menu-main-header {
    height: 166px;

    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;

    margin-bottom: 60px;
}

.menu-header-left {
    width: 1110px;
    flex-grow: 0;
    flex-shrink: 0;
}

.menu-title {
    -unity-font-definition: url("../Fonts/Generated/BrandFont.asset");
    font-size: 40px;
    -unity-font-style: bold;
    color: var(--color-text);

    margin-bottom: 6px;
}

.menu-subtitle {
    width: 980px;

    font-size: 18px;
    color: var(--color-text-muted);

    white-space: normal;

    margin-top: 4px;
}

/* =========================================================
   Section filters
   ========================================================= */

.section-filter-row {
    height: 48px;

    flex-direction: row;
    flex-wrap: nowrap;

    margin-top: 28px;
    margin-bottom: 28px;
}

.section-filter-button {
    height: 40px;
    min-width: 118px;

    border-radius: 20px;

    background-color: rgba(255, 243, 223, 0.07);
    color: var(--color-text-soft);

    border-width: 1px;
    border-color: rgba(255, 243, 223, 0.10);

    font-size: 18px;
    -unity-font-style: bold;

    margin-right: 10px;

    padding-left: 14px;
    padding-right: 14px;
}

.section-filter-button:hover {
    background-color: rgba(255, 243, 223, 0.13);
    color: var(--color-text);
}

.section-filter-selected {
    background-color: var(--color-gold);
    color: #21140d;
    border-color: var(--color-gold);
}

/* =========================================================
   Search
   ========================================================= */

.search-panel {
    width: 410px;
    height: 86px;

    flex-shrink: 0;
}

.search-label {
    font-size: 15px;
    -unity-font-style: bold;
    color: var(--color-gold-soft);

    margin-bottom: 8px;
}

.search-field {
    height: 46px;

    border-radius: 15px;

    background-color: #211712;
    color: #000000;

    border-width: 1px;
    border-color: var(--border-soft);

    font-size: 15px;
}

/* =========================================================
   Dish list / scroll seguro
   ========================================================= */

.dish-scroll {
    width: 1630px;
    height: 880px;

    margin-top: 15px;

    flex-grow: 0;
    flex-shrink: 0;

    overflow: hidden;
    padding-right: 4px;
}

.dish-list {
    flex-direction: row;
    flex-wrap: wrap;
    align-content: flex-start;

    padding-bottom: 26px;
}


.dish-scroll .unity-scroll-view__vertical-scroller {
    width: 8px;

    background-color: rgba(0, 0, 0, 0);

    border-width: 0;

    margin-left: 4px;
    margin-right: 0;
    margin-top: 4px;
    margin-bottom: 4px;

    padding-left: 0;
    padding-right: 0;
}

.dish-scroll .unity-scroller {
    background-color: rgba(0, 0, 0, 0);

    border-width: 0;

    padding-left: 0;
    padding-right: 0;
}

.dish-scroll .unity-scroller__low-button,
.dish-scroll .unity-scroller__high-button {
    display: none;
    width: 0;
    height: 0;
}

.dish-scroll .unity-scroller__slider {
    width: 8px;

    background-color: rgba(0, 0, 0, 0);

    border-width: 0;

    margin-left: 0;
    margin-right: 0;

    padding-left: 0;
    padding-right: 0;
}

.dish-scroll .unity-scroller__slider .unity-base-slider__tracker {
    background-color: rgba(0, 0, 0, 0);

    border-width: 0;
}

.dish-scroll .unity-scroller__slider .unity-base-slider__dragger {
    width: 4px;


    background-color: rgba(214, 170, 91, 0.95);

    border-width: 0;

    margin-left: 2px;
    margin-right: 2px;
}

.dish-scroll .unity-scroller__slider {
    border-color: rgba(0, 0, 0, 0);
}

/* =========================================================
   Dish cards premium
   Sin emojis / producto 3D
   3 columnas
   ========================================================= */

.dish-card {
    width: 510px;
    height: 232px;

    flex-shrink: 0;

    background-color: rgba(35, 24, 18, 0.98);

    border-radius: 28px;

    border-width: 1px;
    border-color: rgba(214, 170, 91, 0.34);

    padding-left: 22px;
    padding-right: 22px;
    padding-top: 20px;
    padding-bottom: 18px;

    margin-right: 22px;
    margin-bottom: 22px;

    overflow: hidden;
}

.dish-card:hover {
    background-color: rgba(46, 31, 23, 0.98);
    border-color: rgba(214, 170, 91, 0.78);
}

.dish-card-selected {
    border-width: 2px;
    border-color: var(--color-gold);
    background-color: rgba(214, 170, 91, 0.13);
}

/* Ya no se usa lĒnea superior */
.dish-card-accent {
    display: none;
}

.dish-card-top {
    height: 32px;

    flex-direction: row;
    justify-content: space-between;
    align-items: center;

    margin-bottom: 12px;
}

.dish-card-model-badge {
    height: 28px;
    min-width: 110px;

    border-radius: 25px;

    background-color: rgba(214, 170, 91, 0.14);
    color: var(--color-gold-soft);

    border-width: 1px;
    border-color: rgba(214, 170, 91, 0.36);

    font-size: 12px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;

    padding-left: 12px;
    padding-right: 12px;
}

.dish-card-category-badge {
    height: 28px;
    max-width: 210px;

    border-radius: 25px;

    color: rgba(255, 243, 223, 0.88);

    border-width: 1px;

    font-size: 12px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;

    padding-left: 14px;
    padding-right: 14px;
}

/* Variantes por categorĒa interna */
.dish-category-pizza {
    background-color: rgba(167, 70, 35, 0.35);
    border-color: rgba(214, 122, 63, 0.55);
}

.dish-category-pasta {
    background-color: rgba(214, 170, 91, 0.20);
    border-color: rgba(214, 170, 91, 0.48);
}

.dish-category-cucina {
    background-color: rgba(111, 23, 23, 0.34);
    border-color: rgba(170, 58, 58, 0.52);
}

.dish-category-abbondanza {
    background-color: rgba(120, 79, 35, 0.36);
    border-color: rgba(214, 170, 91, 0.46);
}

.dish-category-postre {
    background-color: rgba(111, 54, 88, 0.34);
    border-color: rgba(190, 116, 158, 0.50);
}

.dish-category-bebida {
    background-color: rgba(35, 107, 58, 0.30);
    border-color: rgba(73, 151, 91, 0.50);
}

.dish-category-vino {
    background-color: rgba(111, 23, 23, 0.42);
    border-color: rgba(214, 170, 91, 0.42);
}

.dish-category-desayuno {
    background-color: rgba(214, 170, 91, 0.22);
    border-color: rgba(255, 218, 142, 0.48);
}

.dish-category-infantil {
    background-color: rgba(35, 90, 107, 0.34);
    border-color: rgba(96, 168, 194, 0.50);
}

.dish-category-entrada {
    background-color: rgba(35, 107, 58, 0.24);
    border-color: rgba(214, 170, 91, 0.36);
}

.dish-category-default {
    background-color: rgba(255, 243, 223, 0.055);
    border-color: rgba(255, 243, 223, 0.10);
}

.dish-card-name {
    height: 58px;

    font-size: 24px;
    -unity-font-style: bold;
    color: var(--color-text);

    white-space: normal;

    margin-bottom: 8px;
}

.dish-card-description {
    height: 54px;

    font-size: 14px;
    color: rgba(255, 243, 223, 0.64);

    white-space: normal;

    margin-bottom: 12px;
}

.dish-card-meta-row {
    height: 34px;

    flex-direction: row;
    align-items: center;

    margin-top: auto;

    overflow: hidden;
}

.dish-card-meta-chip {
    height: 30px;

    border-radius: 25px;

    background-color: rgba(10, 7, 5, 0.46);
    color: var(--color-gold-soft);

    border-width: 1px;
    border-color: rgba(214, 170, 91, 0.18);

    font-size: 11px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;

    padding-left: 9px;
    padding-right: 9px;

    margin-right: 7px;

    overflow: hidden;
    flex-shrink: 0;
}

.dish-card-meta-chip-wide {
    width: 170px;
}

.dish-card-meta-chip-medium {
    width: 110px;
}

.dish-card-meta-chip-ar {
    width: 82px;

    margin-left: auto;
    margin-right: 0;

    background-color: rgba(35, 107, 58, 0.26);
    color: rgba(255, 243, 223, 0.86);

    border-color: rgba(35, 107, 58, 0.48);
}

.dish-card-icon,
.dish-card-mini-badge,
.dish-card-badge-row,
.dish-card-recommended-ribbon {
    display: none;
}
/* =========================================================
   Empty dish list
   ========================================================= */

.dish-empty-card {
    width: 620px;
    height: 190px;

    border-radius: 28px;

    background-color: rgba(255, 243, 223, 0.055);

    border-width: 1px;
    border-color: rgba(255, 243, 223, 0.10);

    justify-content: center;

    padding: 30px;
}

.dish-empty-title {
    font-size: 25px;
    -unity-font-style: bold;
    color: var(--color-text);

    margin-bottom: 10px;
}

.dish-empty-text {
    font-size: 15px;
    color: var(--color-text-muted);

    white-space: normal;
}

/* =========================================================
   Detail panel
   ========================================================= */

.dish-detail-panel {
    width: 540px;
    height: 1150px;

    flex-shrink: 0;

    background-color: rgba(16, 11, 8, 0.92);

    border-radius: 30px;

    border-width: 1px;
    border-color: rgba(214, 170, 91, 0.28);

    padding: 26px;
}

.menu-section-title {
    -unity-font-definition: url("../Fonts/Generated/InterfaceFontSemiBold.asset");
    font-size: 20px;
    -unity-font-style: bold;
    color: var(--color-gold-soft);

    margin-bottom: 18px;
}

.dish-detail-panel .menu-section-title {
    font-size: 22px;
    margin-bottom: 18px;
}

.detail-preview-card {
    height: 220px;

    background-color: rgba(255, 243, 223, 0.045);

    border-radius: 26px;

    border-width: 1px;
    border-color: rgba(214, 170, 91, 0.20);

    justify-content: center;
    align-items: center;

    margin-bottom: 22px;

    overflow: hidden;
}

.detail-dish-image {
    width: 100%;
    height: 100%;

    background-color: rgba(0, 0, 0, 0);

    -unity-background-scale-mode: scale-to-fit;

    margin-top: 8px;
    margin-bottom: 8px;
}

.detail-ar-badge {
    position: absolute;
    right: 18px;
    top: 18px;

    height: 28px;
    min-width: 122px;

    border-radius: var(--radius-pill);

    background-color: rgba(35, 107, 58, 0.92);
    color: var(--color-text);

    font-size: 12px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;

    padding-left: 12px;
    padding-right: 12px;
}

.detail-name {
    -unity-font-definition: url("../Fonts/Generated/BrandFont.asset");
    font-size: 38px;

    -unity-font-style: bold;
    color: var(--color-text);

    white-space: normal;

    margin-bottom: 8px;
}

.detail-category {
    font-size: 18px;
    -unity-font-style: bold;
    color: var(--color-gold);

    margin-top: 0;
    margin-bottom: 20px;
}

.detail-description {
    min-height: 150px;

    font-size: 18px;
    color: var(--color-text-muted);

    white-space: normal;
    margin-bottom: 20px;
}

.detail-info-row {
    height: 86px;
    flex-direction: row;

}

.detail-info-card {
    width: 390px;
    height: 105px;

    background-color: rgba(255, 243, 223, 0.045);

    border-radius: 18px;

    border-width: 1px;
    border-color: rgba(255, 243, 223, 0.08);

    padding: 14px;

    margin-right: 18px;
}

.detail-info-title {
    font-size: 15px;
    color: var(--color-text-muted);

}

.detail-info-value {
    font-size: 18px;
    -unity-font-style: bold;
    color: var(--color-text);

    white-space: normal;
}

/* =========================================================
   Detail buttons
   ========================================================= */

.detail-actions {
    margin-top: auto;
}

.detail-button {
    width: 100%;
    height: 58px;

    font-size: 22px;
    -unity-font-style: bold;

    margin-bottom: 12px;
}

.detail-button-small {
    width: 100%;
    height: 50px;

    font-size: 15px;
    -unity-font-style: bold;
}

.button-ghost {
    background-color: rgba(255, 243, 223, 0.06);
    color: var(--color-text);

    border-width: 1px;
    border-color: rgba(255, 243, 223, 0.12);
}

.button-ghost:hover {
    background-color: rgba(255, 243, 223, 0.11);
}

/* =========================================================
   Bottom nav
   ========================================================= */

.bottom-navigation {
    position: absolute;

    left: 0;
    right: 0;
    bottom: 0;

    height: 120px;

    background-color: rgba(10, 7, 5, 0.96);

    border-top-width: 1px;
    border-top-color: rgba(214, 170, 91, 0.18);

    flex-direction: row;
    justify-content: center;
    align-items: center;
}

.bottom-nav-button {
    width: 240px;
    height: 55px;

    border-radius: 20px;

    background-color: rgba(255, 243, 223, 0.07);
    color: var(--color-text-soft);

    border-width: 1px;
    border-color: rgba(255, 243, 223, 0.10);

    font-size: 20px;
    -unity-font-style: bold;

    margin-left: 8px;
    margin-right: 8px;
}

.bottom-nav-button:hover {
    background-color: rgba(255, 243, 223, 0.12);
}

.bottom-nav-selected {
    background-color: var(--color-green);
    color: var(--color-text);
    border-color: rgba(35, 107, 58, 0.80);
}

.bottom-nav-has-items {
    background-color: rgba(214, 170, 91, 0.92);
    color: #21140d;
    border-color: var(--color-gold);
}

/* =========================================================
   Menu toast
   ========================================================= */

.menu-toast {
    position: absolute;
    right: 50px;
    bottom: 1300px;

    width: 450px;
    min-height: 86px;

    border-radius: 26px;

    background-color: rgba(35, 107, 58, 0.94);

    border-width: 1px;
    border-color: rgba(214, 170, 91, 0.34);

    padding: 18px;

    justify-content: center;
}

.menu-toast-title {
    font-size: 18px;
    -unity-font-style: bold;
    color: var(--color-text);

    margin-bottom: 4px;
}

.menu-toast-message {
    font-size: 14px;
    color: rgba(255, 243, 223, 0.78);

    white-space: normal;
}